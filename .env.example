# --- Core ---
DATABASE_URL=postgresql+psycopg://nakatomi:nakatomi@localhost:5432/nakatomi
SECRET_KEY=change-me-to-a-long-random-string
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Auth ---
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- File storage ---
# Options: local | s3
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/files
# Used if STORAGE_BACKEND=s3
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Webhooks ---
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3

# --- CORS (rarely needed for headless, but available) ---
CORS_ORIGINS=*

# --- Memory connectors ---
# Comma-separated list: docdeploy, supermemory (more to come)
MEMORY_CONNECTORS=
DOCDEPLOY_API_KEY=
DOCDEPLOY_BASE_URL=https://x402.docdeploy.io
SUPERMEMORY_API_KEY=
SUPERMEMORY_BASE_URL=https://api.supermemory.ai

# --- Dashboard (local audit UI) ---
DASHBOARD_ENABLED=false
