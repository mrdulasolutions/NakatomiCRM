{
  "$schema": "https://railway.app/template.schema.json",
  "name": "Nakatomi CRM",
  "description": "Headless, agent-native CRM. REST + MCP. For Claude, ChatGPT, Perplexity, Cursor.",
  "image": null,
  "readme": "README.md",
  "services": [
    {
      "name": "nakatomi",
      "source": {
        "type": "github",
        "repo": "mrdulasolutions/NakatomiCRM",
        "branch": "main",
        "dockerfile": "Dockerfile"
      },
      "variables": {
        "SECRET_KEY": {
          "description": "Signs JWTs and sensitive tokens. Generate with `openssl rand -hex 32`.",
          "required": true,
          "generate": "secret"
        },
        "DATABASE_URL": {
          "description": "Connection string to the Nakatomi Postgres. Injected automatically from the Postgres plugin.",
          "required": true,
          "value": "${{nakatomi-postgres.DATABASE_URL}}"
        },
        "STORAGE_BACKEND": {
          "description": "Where to put uploaded files. Use `local` (plus a Railway volume) or `s3`.",
          "required": false,
          "default": "local"
        },
        "STORAGE_LOCAL_PATH": {
          "description": "Mounted volume path for file storage when STORAGE_BACKEND=local.",
          "default": "/app/data/files"
        },
        "S3_BUCKET": { "required": false },
        "S3_REGION": { "required": false, "default": "us-east-1" },
        "S3_ENDPOINT_URL": { "required": false, "description": "Leave blank for AWS; set for R2 or MinIO." },
        "S3_ACCESS_KEY": { "required": false },
        "S3_SECRET_KEY": { "required": false },
        "MEMORY_CONNECTORS": {
          "description": "Comma-separated list: docdeploy, supermemory. Leave blank to disable.",
          "default": ""
        },
        "DOCDEPLOY_API_KEY": { "required": false },
        "SUPERMEMORY_API_KEY": { "required": false },
        "DASHBOARD_ENABLED": {
          "description": "Expose the audit dashboard at /dashboard. Leave off in production unless you put it behind auth.",
          "default": "false"
        },
        "CORS_ORIGINS": { "default": "*" },
        "JWT_EXPIRE_MINUTES": { "default": "60" },
        "WEBHOOK_TIMEOUT_SECONDS": { "default": "10" },
        "WEBHOOK_MAX_RETRIES": { "default": "3" }
      },
      "volumes": [
        { "mountPath": "/app/data", "name": "nakatomi-data" }
      ]
    },
    {
      "name": "nakatomi-postgres",
      "source": { "type": "image", "image": "postgres:16-alpine" },
      "variables": {
        "POSTGRES_USER": { "default": "nakatomi" },
        "POSTGRES_PASSWORD": { "required": true, "generate": "secret" },
        "POSTGRES_DB": { "default": "nakatomi" }
      },
      "volumes": [
        { "mountPath": "/var/lib/postgresql/data", "name": "nakatomi-pg-data" }
      ]
    }
  ]
}
